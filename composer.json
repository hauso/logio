{
    "name": "logio/product-information-search",
    "description": "Framework-less PHP application for product information search.",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Logio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Logio\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs"
    },
    "config": {
        "sort-packages": true
    }
}
